{
    "registry_path": "../data/registry.csv",
    "embed": {
        "model_name": "BAAI/bge-small-en-v1.5",
        "embed_dim": 384,
        "batch_size": 64,
        "normalize": true
    },
    "retrieval": {
        "mode": "hybrid",
        "candidate_multiplier": 3,
        "rrf_k": 60,
        "min_token_length": 3
    },
    "evaluation": {
        "queries_path": "./data/queries.jsonl",
        "qrels_path": "./data/qrels.jsonl",
        "top_k": 5,
        "seed": 42,
        "results_dir": "./results"
    },
    "answerer": {
        "type": "none"
    },
    "experiments": [
        {
            "name": "neural",
            "source_chunks_dir": "../data/neural_chunks",
            "enriched_output_dir": "./outputs/enriched_neural",
            "index_db_path": "./outputs/vectorstore_neural.db"
        }
    ]
}
